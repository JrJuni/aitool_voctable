# VOC Table 환경변수 설정 예시
# 이 파일을 `.env`로 복사한 뒤 값을 채우세요(.env는 커밋 금지).
# docker compose는 같은 디렉터리의 .env를 자동으로 읽습니다.

# =============================================================================
# 필수 시크릿 (코드에 기본값 없음 — 미설정 시 백엔드가 기동 실패)
# =============================================================================
# JWT 서명 키 (충분히 긴 무작위 문자열로 설정)
JWT_SECRET=replace-with-a-long-random-secret
TOKEN_EXPIRE_MIN=30

# 백엔드 DB 접속 URL (컨테이너 기준 예시)
DATABASE_URL=replace-with-db-url-e.g-mysql+pymysql://user:pass@mysql:3306/voc_database

# MySQL 컨테이너 자격증명 (docker-compose가 사용)
MYSQL_ROOT_PASSWORD=replace-with-root-password
MYSQL_PASSWORD=replace-with-db-password
MYSQL_USER=voc_user
MYSQL_DATABASE=voc_database

# =============================================================================
# 기본 관리자 / 비밀번호 정책 (시드 엔드포인트 및 비밀번호 초기화에 사용)
# =============================================================================
DEFAULT_ADMIN_EMAIL=admin@example.com
# 미설정 시 비밀번호 초기화/시드 기능은 비활성화됩니다.
DEFAULT_RESET_PW=replace-with-default-reset-password

# =============================================================================
# 데이터 소스 우선순위 (프론트엔드)
# =============================================================================
# "api_first": API 서버 우선 / "local_first": 로컬 DB 우선
DATA_SOURCE_PRIORITY=api_first

# =============================================================================
# API 서버 설정 (프론트엔드 → 백엔드)
# =============================================================================
API_BASE_URL=http://localhost:8000

# =============================================================================
# 프론트엔드 로컬 백업 DB 설정 (local_first 모드에서만)
# =============================================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=voc_table

# =============================================================================
# 쿠키 보안 설정
# =============================================================================
COOKIE_SECRET_KEY=replace-with-a-long-random-cookie-key

# 로그 레벨
LOG_LEVEL=INFO
